# Copy this file to .env and fill in your key.
#   copy .env.example .env

OPENAI_API_KEY=
# Clip Studio AI Reliability Profile defaults to SAFE in the UI (gpt-4o-mini — most stable).
# MAX QUALITY profile uses gpt-5-mini with gpt-4o-mini JSON fallback.
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Used once when gpt-5* returns empty or invalid JSON (clip analysis, grounding, split).
OPENAI_MODEL_JSON_FALLBACK=gpt-4o-mini

# Optional: set to 1 to require a valid Supabase JWT on /api/claims-intelligence
# (uses SUPABASE_URL + SUPABASE_ANON_KEY on the server).
# CLAIMS_INTEL_REQUIRE_AUTH=

# Server-side Supabase (for JWT verification when CLAIMS_INTEL_REQUIRE_AUTH=1)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Vite — same project Supabase keys for browser sessions (optional)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Local dev: Vite proxies /api to Vercel CLI (default http://127.0.0.1:3000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# FPS for [HH:MM:SS:FF - ...] transcript lines (default 24).
TRANSCRIPT_BRACKET_FPS=24

# Clip Studio — force CPU paths even when GPU is available (optional)
# FORCE_CPU_VIDEO=1
# FORCE_CPU_WHISPER=1

# Optional: full path to ffmpeg when the IDE/Streamlit process does not inherit your shell PATH (Windows common).
# FFMPEG_BINARY=C:/Users/you/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-7.1-full_build/bin/ffmpeg.exe

# Optional: CUDA toolkit root so cublas64_12.dll and friends resolve for faster-whisper / CTranslate2 (Windows).
# CUDA_PATH=C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.4
