# Copy this file to .env and fill in your values.
#   copy .env.example .env
#
# ─────────────────────────────────────────────────────────────
# OPENAI
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Clip Studio AI Reliability Profile defaults to SAFE in the UI (gpt-4o-mini — most stable).
# MAX QUALITY profile uses gpt-4o with gpt-4o-mini JSON fallback.
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Used once when gpt-5* returns empty or invalid JSON (clip analysis, grounding, split).
OPENAI_MODEL_JSON_FALLBACK=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# SUPABASE  (Vercel serverless + browser client)
# ─────────────────────────────────────────────────────────────
# Server-side: used by API functions (stripe-webhook, validate-license, editor-intelligence)
SUPABASE_URL=
# Anon key — safe to expose in browser; used by editor-intelligence JWT verification
SUPABASE_ANON_KEY=
# Service role key — NEVER expose in browser; used by stripe-webhook + validate-license
SUPABASE_SERVICE_ROLE_KEY=

# Vite — same project keys exposed to the browser build (VITE_ prefix required by Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: require a valid Supabase JWT on /api/editor-intelligence
# Set to 1 to enforce authentication on that endpoint.
# EDITOR_INTEL_REQUIRE_AUTH=

# ─────────────────────────────────────────────────────────────
# STRIPE  (license payments)
# ─────────────────────────────────────────────────────────────
# Secret key from Stripe dashboard (sk_live_... for prod, sk_test_... for dev)
STRIPE_SECRET_KEY=
# Webhook signing secret — from Stripe dashboard → Developers → Webhooks → your endpoint
# Looks like: whsec_...
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# RESEND  (transactional email — license key delivery)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender address — must match a domain you've verified in Resend
# Format: "Display Name <address@yourdomain.com>"
RESEND_FROM_EMAIL=RT365 <licenses@yourdomain.com>

# ─────────────────────────────────────────────────────────────
# BRANDING / SUPPORT  (used in emails and the activation UI)
# ─────────────────────────────────────────────────────────────
SUPPORT_EMAIL=support@yourdomain.com
# Direct download link shown in the license confirmation email and landing page
APP_DOWNLOAD_URL=

# Vite — landing page Stripe Payment Links and branding
VITE_STRIPE_CHECKOUT_ONETIME=
VITE_STRIPE_CHECKOUT_SUBSCRIPTION=
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_APP_DOWNLOAD_URL=

# ─────────────────────────────────────────────────────────────
# RT365 AI CLIP STUDIO  (Python / Streamlit)
# ─────────────────────────────────────────────────────────────
# Base URL of your deployed Vercel app — used by the Python client to call
# /api/validate-license on first launch (no trailing slash)
RT365_API_URL=https://your-app.vercel.app

# Internal master override key — set only on developer machines to bypass
# license enforcement entirely. Never ship this to end users.
# RT365_MASTER_KEY=

# HuggingFace token — required for pyannote speaker diarization models
HF_TOKEN=

# Per-session OpenAI token cap. Prevents runaway API costs on long videos.
# Increase for 3-hour+ podcasts. Set to 0 to disable entirely.
RT365_SESSION_TOKEN_CAP=80000

# Clip Studio — force CPU paths even when GPU is available (optional)
# FORCE_CPU_VIDEO=1
# FORCE_CPU_WHISPER=1

# Optional: full path to ffmpeg when the IDE/Streamlit process does not inherit
# your shell PATH (common on Windows).
# FFMPEG_BINARY=C:/Users/you/AppData/Local/.../ffmpeg.exe

# Optional: CUDA toolkit root so cublas64_12.dll resolves for faster-whisper (Windows)
# CUDA_PATH=C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.4

# FPS for [HH:MM:SS:FF - ...] transcript lines (default 24).
TRANSCRIPT_BRACKET_FPS=24

# Local dev: Vite proxies /api to Vercel CLI (default http://127.0.0.1:3000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
